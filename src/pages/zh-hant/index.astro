---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/layout/Container.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import Section from "@/components/layout/Section.astro";
import CoverHero from "@/components/home/CoverHero.astro";
import ThesisTriptych from "@/components/home/ThesisTriptych.astro";
import ManifestoSplit from "@/components/home/ManifestoSplit.astro";
import PillarsTriad from "@/components/home/PillarsTriad.astro";
import PortraitTriptych from "@/components/home/PortraitTriptych.astro";
import LibraryPreview from "@/components/home/LibraryPreview.astro";
import WeChatDrawer from "@/components/wechat/WeChatDrawer.astro";

const locale = "zh-hant";
const path = Astro.url.pathname;
---
<Layout
  locale={locale}
  title="AMZ Sensory | 花香優先的極淺烘焙"
  description="AMZ Sensory 專注花香優先、結構分層與乾淨收尾的極淺烘焙。"
>
  <Header locale={locale} path={path} />
  <CoverHero locale={locale} />
  <ThesisTriptych locale={locale} />
  <ManifestoSplit locale={locale} />
  <PillarsTriad locale={locale} />
  <PortraitTriptych locale={locale} />

  <Section>
    <Container class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
      <div class="order-2 md:order-1">
        <p class="text-xs tracking-[0.18em] uppercase text-muted">Where / Who</p>
        <h2 class="mt-3 font-serif text-2xl tracking-[-0.01em]">風土與關係</h2>
        <ul class="mt-6 space-y-3 text-sm text-text/90">
          <li>來源可追溯 · traceable</li>
          <li>關係長期 · long-term</li>
          <li>描述可驗證 · verifiable</li>
        </ul>
      </div>
      <div class="order-1 md:order-2">
        <div class="rounded-[var(--radius)] border border-border/10 overflow-hidden" style="aspect-ratio:4/5;">
          <img src="/covers/clarity.jpg" alt="Terroir" class="h-full w-full object-cover" loading="lazy" />
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="tight">
    <Container class="border border-border/10 rounded-[var(--radius)] p-8 md:p-10 bg-surface">
      <p class="text-xs tracking-[0.18em] uppercase text-muted">Sustainability</p>
      <div class="mt-5 grid gap-4">
        <div class="flex items-start justify-between gap-4 border-b border-border/10 pb-4">
          <div>
            <p class="font-serif text-lg tracking-[-0.01em]">Packaging</p>
            <p class="mt-1 text-sm text-muted">鋁瓶密封，減少氧化與反覆包材。</p>
          </div>
        </div>
        <div class="flex items-start justify-between gap-4 border-b border-border/10 pb-4">
          <div>
            <p class="font-serif text-lg tracking-[-0.01em]">Buying</p>
            <p class="mt-1 text-sm text-muted">只買理解的批次，關係透明，數字可追。</p>
          </div>
        </div>
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="font-serif text-lg tracking-[-0.01em]">Waste</p>
            <p class="mt-1 text-sm text-muted">節制，減量，避免口號式承諾。</p>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="tight">
    <Container>
      <p class="text-xs tracking-[0.18em] uppercase text-muted">How we roast</p>
      <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="rounded-[var(--radius)] border border-border/10 p-5 bg-surface">
          <p class="font-serif text-lg tracking-[-0.01em]">Temperature Bands</p>
          <p class="mt-2 text-sm text-muted">分層而不是堆料。</p>
        </div>
        <div class="rounded-[var(--radius)] border border-border/10 p-5 bg-surface">
          <p class="font-serif text-lg tracking-[-0.01em]">Development</p>
          <p class="mt-2 text-sm text-muted">保留香氣的骨架。</p>
        </div>
        <div class="rounded-[var(--radius)] border border-border/10 p-5 bg-surface">
          <p class="font-serif text-lg tracking-[-0.01em]">Solubility</p>
          <p class="mt-2 text-sm text-muted">讓萃取更可控。</p>
        </div>
        <div class="rounded-[var(--radius)] border border-border/10 p-5 bg-surface">
          <p class="font-serif text-lg tracking-[-0.01em]">Finish</p>
          <p class="mt-2 text-sm text-muted">乾淨收尾，沒有拖泥帶水。</p>
        </div>
      </div>
    </Container>
  </Section>

  <LibraryPreview locale={locale} />

  <Footer />
  <WeChatDrawer />
</Layout>
