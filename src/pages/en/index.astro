---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/layout/Container.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import Section from "@/components/layout/Section.astro";
import CoverHero from "@/components/home/CoverHero.astro";
import ThesisTriptych from "@/components/home/ThesisTriptych.astro";
import ManifestoSplit from "@/components/home/ManifestoSplit.astro";
import PillarsTriad from "@/components/home/PillarsTriad.astro";
import PortraitTriptych from "@/components/home/PortraitTriptych.astro";
import LibraryPreview from "@/components/home/LibraryPreview.astro";
import WeChatDrawer from "@/components/wechat/WeChatDrawer.astro";

const locale = "en";
const path = Astro.url.pathname;
---

<Layout
  locale={locale}
  title="AMZ Sensory | Floral-first Ultra Light Coffee"
  description="Floral-first ultra-light roasting with layered structure and clean finish."
>
  <Header locale={locale} path={path} />
  <CoverHero locale={locale} />
  <ThesisTriptych locale={locale} />
  <ManifestoSplit locale={locale} />
  <PillarsTriad locale={locale} />
  <PortraitTriptych locale={locale} />

  <Section>
    <Container
      class="grid grid-cols-1 items-center gap-10 md:grid-cols-2 md:gap-16"
    >
      <div class="order-2 md:order-1" data-reveal data-reveal-step="0">
        <p class="text-xs tracking-[0.18em] text-muted uppercase">
          Where / Who
        </p>
        <h2 class="mt-3 font-serif text-2xl tracking-[-0.01em]">
          Terroir & Relationships
        </h2>
        <ul class="mt-6 space-y-3 text-sm text-text/90">
          <li>Traceable origins.</li>
          <li>Long-term relationships.</li>
          <li>Verifiable descriptions.</li>
        </ul>
      </div>
      <div class="order-1 md:order-2" data-reveal data-reveal-step="1">
        <div
          class="overflow-hidden rounded-[var(--radius)] border border-border/10"
          style="aspect-ratio:4/5;"
        >
          <img
            src="/covers/clarity.jpg"
            alt="Terroir"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="tight">
    <Container
      class="rounded-[var(--radius)] border border-border/10 bg-surface p-8 md:p-10"
    >
      <p
        class="text-xs tracking-[0.18em] text-muted uppercase"
        data-reveal
        data-reveal-step="0"
      >
        Sustainability
      </p>
      <div class="mt-5 grid gap-4">
        <div
          class="flex items-start justify-between gap-4 border-b border-border/10 pb-4"
          data-reveal
          data-reveal-step="1"
        >
          <div>
            <p class="font-serif text-lg tracking-[-0.01em]">Packaging</p>
            <p class="mt-1 text-sm text-muted">
              Aluminum bottles, sealed to reduce oxygen and extra packaging.
            </p>
          </div>
        </div>
        <div
          class="flex items-start justify-between gap-4 border-b border-border/10 pb-4"
          data-reveal
          data-reveal-step="2"
        >
          <div>
            <p class="font-serif text-lg tracking-[-0.01em]">Buying</p>
            <p class="mt-1 text-sm text-muted">
              We only buy lots we understand—transparent relationships,
              traceable numbers.
            </p>
          </div>
        </div>
        <div
          class="flex items-start justify-between gap-4"
          data-reveal
          data-reveal-step="3"
        >
          <div>
            <p class="font-serif text-lg tracking-[-0.01em]">Waste</p>
            <p class="mt-1 text-sm text-muted">
              Restraint and reduction—no slogans.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <Section tone="tight">
    <Container>
      <p
        class="text-xs tracking-[0.18em] text-muted uppercase"
        data-reveal
        data-reveal-step="0"
      >
        How we roast
      </p>
      <div class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8">
        <div
          class="rounded-[var(--radius)] border border-border/10 bg-surface p-5"
          data-reveal
          data-reveal-step="1"
        >
          <p class="font-serif text-lg tracking-[-0.01em]">Temperature Bands</p>
          <p class="mt-2 text-sm text-muted">Layered, never stacked.</p>
        </div>
        <div
          class="rounded-[var(--radius)] border border-border/10 bg-surface p-5"
          data-reveal
          data-reveal-step="2"
        >
          <p class="font-serif text-lg tracking-[-0.01em]">Development</p>
          <p class="mt-2 text-sm text-muted">Keep the aromatic skeleton.</p>
        </div>
        <div
          class="rounded-[var(--radius)] border border-border/10 bg-surface p-5"
          data-reveal
          data-reveal-step="3"
        >
          <p class="font-serif text-lg tracking-[-0.01em]">Solubility</p>
          <p class="mt-2 text-sm text-muted">Extraction stays controllable.</p>
        </div>
        <div
          class="rounded-[var(--radius)] border border-border/10 bg-surface p-5"
          data-reveal
          data-reveal-step="4"
        >
          <p class="font-serif text-lg tracking-[-0.01em]">Finish</p>
          <p class="mt-2 text-sm text-muted">Clean finish, no drag.</p>
        </div>
      </div>
    </Container>
  </Section>

  <LibraryPreview locale={locale} />

  <Footer />
  <WeChatDrawer />

  <script>
    import { bindScrollReveal } from "@/scripts/reveal";

    bindScrollReveal();
  </script>
</Layout>
