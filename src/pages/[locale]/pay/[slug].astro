---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Container from "@/components/layout/Container.astro";
import Section from "@/components/layout/Section.astro";
import Aspect from "@/components/ui/Aspect.astro";
import { LOCALES, type Locale } from "@/data/locales";
import { getAllCoffees } from "@/utils/getCoffees";
import { QR_SRC, WECHAT_ID } from "@/components/wechat/wechat";
import WeChatDrawer from "@/components/wechat/WeChatDrawer.astro";

export async function getStaticPaths() {
  const coffees = await getAllCoffees();
  return LOCALES.flatMap(locale =>
    coffees.map(coffee => ({
      params: {
        locale,
        slug: coffee.data.slug,
      },
      props: { coffee },
    }))
  );
}

const localeParam = Astro.params.locale;
if (!(localeParam && LOCALES.includes(localeParam as Locale))) {
  throw new Error(`Invalid locale: ${localeParam}`);
}

const locale = localeParam as Locale;
const path = Astro.url.pathname;
const { coffee } = Astro.props;

const title = coffee.data.title[locale];
const payTitle = locale === "en" ? "Payment" : "付款";
const summary = locale === "en"
  ? "Scan the WeChat QR to complete your order."
  : "請使用 WeChat 掃描 QR 完成訂單。";
---

<Layout
  locale={locale}
  title={`AMZ Sensory | ${title} ${payTitle}`}
  description={summary}
  ogImage={coffee.data.cover}
>
  <Header locale={locale} path={path} />

  <Section>
    <Container class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-start">
      <div class="grid gap-6">
        <div>
          <p class="text-xs tracking-[0.18em] uppercase text-muted">{payTitle}</p>
          <h1 class="mt-3 font-serif text-4xl tracking-[-0.02em]">{title}</h1>
          <p class="mt-3 text-sm text-muted">{summary}</p>
        </div>

        <div class="grid gap-2 text-sm text-muted">
          <p>{coffee.data.origin[locale]} · {coffee.data.process[locale]}</p>
          <p>{coffee.data.tasting[locale].slice(0, 3).join(" · ")}</p>
        </div>

        <div class="grid gap-2" data-pay-wechat-id={WECHAT_ID}>
          <p class="text-xs text-muted">WeChat ID</p>
          <div class="flex items-center justify-between gap-3 border border-border/10 rounded-[var(--radius)] px-4 py-3">
            <code class="text-sm text-text">{WECHAT_ID}</code>
            <button class="text-xs text-text hover:underline underline-offset-4" data-copy-wechat-id type="button">
              Copy
            </button>
          </div>
        </div>

        <div class="flex items-center gap-6 text-xs">
          <a href={`/${locale}/coffee/${coffee.data.slug}/`} class="text-text hover:underline underline-offset-4">
            {locale === "en" ? "Back to Product" : "回到商品頁"}
          </a>
          <button type="button" class="text-text hover:underline underline-offset-4" data-wechat-open>
            {locale === "en" ? "Open WeChat Drawer" : "開啟 WeChat 視窗"}
          </button>
        </div>
      </div>

      <div class="border border-border/10 rounded-[var(--radius)] p-6 bg-surface">
        <Aspect ratio="1/1" class="rounded-none">
          <img
            src={QR_SRC}
            alt="WeChat QR"
            class="h-full w-full object-contain"
            loading="lazy"
            data-pay-qr
          />
        </Aspect>
        <p class="hidden mt-4 text-xs text-muted" data-pay-qr-fallback>
          {locale === "en" ? "QR image unavailable. Use WeChat ID above." : "QR 圖片載入失敗，請使用上方 WeChat ID。"}
        </p>
      </div>
    </Container>
  </Section>

  <Footer />
  <WeChatDrawer />
</Layout>

<script>
  const copyButton = document.querySelector<HTMLButtonElement>("[data-copy-wechat-id]");
  const wechatId =
    document
      .querySelector<HTMLElement>("[data-pay-wechat-id]")
      ?.dataset.payWechatId ?? "AMZ_SENSORY";
  copyButton?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(wechatId);
      copyButton.textContent = "Copied";
      setTimeout(() => {
        copyButton.textContent = "Copy";
      }, 1000);
    } catch {
      copyButton.textContent = wechatId;
    }
  });

  const qrImage = document.querySelector<HTMLImageElement>("[data-pay-qr]");
  const qrFallback = document.querySelector<HTMLElement>("[data-pay-qr-fallback]");
  qrImage?.addEventListener("error", () => {
    qrFallback?.classList.remove("hidden");
  });
</script>
