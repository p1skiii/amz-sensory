---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Container from "@/components/layout/Container.astro";
import Section from "@/components/layout/Section.astro";
import Aspect from "@/components/ui/Aspect.astro";
import WeChatDrawer from "@/components/wechat/WeChatDrawer.astro";
import { isLocale, type Locale } from "@/data/locales";
import { getCoffeeBySlugOrLegacy } from "@/utils/getCoffees";

export const prerender = false;

const localeParam = Astro.params.locale;
if (!isLocale(localeParam)) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const slugParam = Astro.params.slug;
if (!slugParam) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}
const slug = slugParam.toLowerCase();
if (!/^[a-z0-9-]+$/.test(slug)) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const locale: Locale = localeParam;
const path = Astro.url.pathname;
const { coffee, matchedLegacy } = await getCoffeeBySlugOrLegacy(slug);

if (!coffee) {
  return Astro.redirect(`/${locale}/coffee/`, 302);
}

if (matchedLegacy) {
  return Astro.redirect(`/${locale}/coffee/${coffee.data.slug}/`, 301);
}

const title = coffee.data.title[locale];
const origin = coffee.data.origin[locale];
const process = coffee.data.process[locale];
const price = `HK$${coffee.data.priceHkd} / 100g`;
const tasting = coffee.data.tasting[locale];
const notes = coffee.data.notes[locale];
const story = coffee.data.story[locale];
---

<Layout
  locale={locale}
  title={`AMZ Sensory | ${title}`}
  description={notes}
  ogImage={coffee.data.cover}
>
  <Header locale={locale} path={path} />

  <Section>
    <Container
      class="grid grid-cols-1 items-start gap-10 md:grid-cols-2 md:gap-16"
    >
      <div>
        <Aspect class="rounded-[var(--radius)] bg-surface">
          <div class="h-full w-full rounded-[var(--radius)] border border-border/15 bg-white/35 p-3 md:p-4">
            <img
              src={coffee.data.cover}
              alt={title}
              class="h-full w-full object-contain"
              loading="lazy"
            />
          </div>
        </Aspect>
      </div>

      <div class="grid gap-6">
        <div>
          <p class="text-xs tracking-[0.18em] text-muted uppercase">Coffee</p>
          <h1 class="mt-3 font-serif text-4xl tracking-[-0.02em]">{title}</h1>
          <p class="mt-3 text-sm text-text/90">{origin} · {process}</p>
          <p class="mt-2 text-xs tracking-[0.12em] text-muted uppercase">
            {price}
          </p>
        </div>

        <div class="grid gap-3">
          <p class="text-xs tracking-[0.18em] text-muted uppercase">
            {locale === "en" ? "Tasting" : "風味"}
          </p>
          <p class="text-sm text-muted">{tasting.join(" · ")}</p>
        </div>

        <div class="grid gap-3 text-sm text-muted">
          <p>{notes}</p>
          <p>{story}</p>
        </div>

        <div class="grid gap-4">
          <div class="flex items-center gap-2 text-xs">
            <button
              type="button"
              class="rounded-[calc(var(--radius)*0.72)] border border-border/20 px-2 py-1 transition duration-150 ease-editorial hover:border-border/40"
              data-item-qty-dec
            >
              −
            </button>
            <input
              type="number"
              min="1"
              max="99"
              value="1"
              class="w-14 rounded-[calc(var(--radius)*0.72)] border border-border/20 px-2 py-1 text-center text-text"
              data-item-qty
            />
            <button
              type="button"
              class="rounded-[calc(var(--radius)*0.72)] border border-border/20 px-2 py-1 transition duration-150 ease-editorial hover:border-border/40"
              data-item-qty-inc
            >
              +
            </button>
          </div>

          <button
            type="button"
            class="w-fit rounded-[calc(var(--radius)*0.8)] border border-border/25 px-4 py-2 text-xs tracking-[0.12em] text-text uppercase transition duration-150 ease-editorial hover:border-border/45"
            data-detail-add
            data-stable-key={coffee.data.stable_key}
            data-slug={coffee.data.slug}
            data-title={title}
            data-price={coffee.data.priceHkd}
            data-cover={coffee.data.cover}
            data-added-label={locale === "en" ? "Added" : "已加入"}
          >
            {locale === "en" ? "Add to Cart" : "加入購物車"}
          </button>
        </div>

        <div class="flex items-center gap-6 text-xs">
          <a
            href={`/${locale}/coffee/`}
            class="text-text underline-offset-4 hover:underline"
          >
            {locale === "en" ? "Back to Coffee" : "回到作品庫"}
          </a>
        </div>
      </div>
    </Container>
  </Section>

  <Footer />
  <WeChatDrawer />

  <script>
    import { addToCart, bindCartCountBadges } from "@/scripts/cart";

    type CoffeeDetailWindow = Window & {
      __amzCoffeeDetailBound?: boolean;
      __amzCoffeeDetailCleanup?: () => void;
    };

    const setupCoffeeDetail = (): boolean => {
      const qtyInput =
        document.querySelector<HTMLInputElement>("[data-item-qty]");
      const decButton = document.querySelector<HTMLButtonElement>(
        "[data-item-qty-dec]"
      );
      const incButton = document.querySelector<HTMLButtonElement>(
        "[data-item-qty-inc]"
      );
      const addButton =
        document.querySelector<HTMLButtonElement>("[data-detail-add]");

      bindCartCountBadges();

      if (!qtyInput || !decButton || !incButton || !addButton) {
        return false;
      }

      const win = window as CoffeeDetailWindow;
      win.__amzCoffeeDetailCleanup?.();

      const normalizeQty = (value: number) =>
        Math.max(1, Math.min(99, Math.floor(value)));
      const currentQty = () => normalizeQty(Number(qtyInput.value ?? "1"));

      const setQty = (value: number) => {
        qtyInput.value = String(normalizeQty(value));
      };

      let resetTimer = 0;

      const handleDec = () => {
        setQty(currentQty() - 1);
      };
      const handleInc = () => {
        setQty(currentQty() + 1);
      };
      const handleQtyChange = () => {
        setQty(currentQty());
      };
      const handleAdd = () => {
        const stableKey = addButton.dataset.stableKey;
        const slug = addButton.dataset.slug;
        const title = addButton.dataset.title;
        const cover = addButton.dataset.cover;
        const price = Number(addButton.dataset.price);

        if (
          !stableKey ||
          !slug ||
          !title ||
          !cover ||
          !Number.isFinite(price) ||
          price <= 0
        ) {
          return;
        }

        addToCart(
          {
            stable_key: stableKey,
            slug,
            title,
            cover,
            price_hkd: price,
          },
          currentQty()
        );

        const previous = addButton.textContent ?? "";
        addButton.textContent = addButton.dataset.addedLabel ?? "Added";
        if (resetTimer > 0) {
          window.clearTimeout(resetTimer);
        }
        resetTimer = window.setTimeout(() => {
          addButton.textContent = previous;
        }, 900);
      };

      decButton.addEventListener("click", handleDec);
      incButton.addEventListener("click", handleInc);
      qtyInput.addEventListener("change", handleQtyChange);
      addButton.addEventListener("click", handleAdd);

      win.__amzCoffeeDetailCleanup = () => {
        decButton.removeEventListener("click", handleDec);
        incButton.removeEventListener("click", handleInc);
        qtyInput.removeEventListener("change", handleQtyChange);
        addButton.removeEventListener("click", handleAdd);
        if (resetTimer > 0) {
          window.clearTimeout(resetTimer);
        }
      };

      return true;
    };

    const runCoffeeDetailInit = () => {
      if (setupCoffeeDetail()) return;
      window.requestAnimationFrame(() => {
        setupCoffeeDetail();
      });
    };

    const win = window as CoffeeDetailWindow;
    if (!win.__amzCoffeeDetailBound) {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", runCoffeeDetailInit, {
          once: true,
        });
      } else {
        runCoffeeDetailInit();
      }
      document.addEventListener("astro:page-load", runCoffeeDetailInit);
      win.__amzCoffeeDetailBound = true;
    } else {
      runCoffeeDetailInit();
    }
  </script>
</Layout>
