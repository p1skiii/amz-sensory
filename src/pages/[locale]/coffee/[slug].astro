---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Container from "@/components/layout/Container.astro";
import Section from "@/components/layout/Section.astro";
import Aspect from "@/components/ui/Aspect.astro";
import WeChatDrawer from "@/components/wechat/WeChatDrawer.astro";
import { LOCALES, type Locale } from "@/data/locales";
import { getAllCoffees } from "@/utils/getCoffees";

export async function getStaticPaths() {
  const coffees = await getAllCoffees();
  return LOCALES.flatMap(locale =>
    coffees.map(coffee => ({
      params: {
        locale,
        slug: coffee.data.slug,
      },
      props: { coffee },
    }))
  );
}

const localeParam = Astro.params.locale;
if (!(localeParam && LOCALES.includes(localeParam as Locale))) {
  throw new Error(`Invalid locale: ${localeParam}`);
}

const locale = localeParam as Locale;
const path = Astro.url.pathname;
const { coffee } = Astro.props;

const title = coffee.data.title[locale];
const origin = coffee.data.origin[locale];
const process = coffee.data.process[locale];
const price = `HK$${coffee.data.priceHkd} / 100g`;
const tasting = coffee.data.tasting[locale];
const notes = coffee.data.notes[locale];
const story = coffee.data.story[locale];
---

<Layout
  locale={locale}
  title={`AMZ Sensory | ${title}`}
  description={notes}
  ogImage={coffee.data.cover}
>
  <Header locale={locale} path={path} />

  <Section>
    <Container class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-start">
      <div>
        <Aspect>
          <img
            src={coffee.data.cover}
            alt={title}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </Aspect>
      </div>

      <div class="grid gap-6">
        <div>
          <p class="text-xs tracking-[0.18em] uppercase text-muted">Coffee</p>
          <h1 class="mt-3 font-serif text-4xl tracking-[-0.02em]">{title}</h1>
          <p class="mt-3 text-sm text-text/90">{origin} · {process}</p>
          <p class="mt-2 text-xs tracking-[0.12em] text-muted uppercase">{price}</p>
        </div>

        <div class="grid gap-3">
          <p class="text-xs tracking-[0.18em] uppercase text-muted">
            {locale === "en" ? "Tasting" : "風味"}
          </p>
          <p class="text-sm text-muted">{tasting.join(" · ")}</p>
        </div>

        <div class="grid gap-3 text-sm text-muted">
          <p>{notes}</p>
          <p>{story}</p>
        </div>

        <div class="flex items-center gap-6 text-xs">
          <a href={`/${locale}/coffee/`} class="text-text hover:underline underline-offset-4">
            {locale === "en" ? "Back to Coffee" : "回到作品庫"}
          </a>
        </div>
      </div>
    </Container>
  </Section>

  <Footer />
  <WeChatDrawer />
</Layout>
