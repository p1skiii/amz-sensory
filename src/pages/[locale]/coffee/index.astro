---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Container from "@/components/layout/Container.astro";
import Section from "@/components/layout/Section.astro";
import CoffeeCard from "@/components/coffee/CoffeeCard.astro";
import WeChatDrawer from "@/components/wechat/WeChatDrawer.astro";
import { LOCALES, type Locale } from "@/data/locales";
import { getAllCoffees } from "@/utils/getCoffees";

export const prerender = false;

const localeParam = Astro.params.locale;
if (!(localeParam && LOCALES.includes(localeParam as Locale))) {
  throw new Error(`Invalid locale: ${localeParam}`);
}

const locale = localeParam as Locale;
const path = Astro.url.pathname;
const coffees = await getAllCoffees();

const title = locale === "en" ? "Coffee" : "Coffee";
const description =
  locale === "en"
    ? "Current AMZ Sensory releases with tasting notes."
    : "AMZ Sensory 當前作品與風味資訊。";
---

<Layout locale={locale} title={`AMZ Sensory | ${title}`} description={description}>
  <Header locale={locale} path={path} />

  <Section>
    <Container>
      <div class="flex flex-wrap items-end justify-between gap-5">
        <div>
          <p class="text-xs tracking-[0.18em] uppercase text-muted">Current Releases</p>
          <h1 class="mt-3 font-serif text-4xl tracking-[-0.02em]">
            {locale === "en" ? "Coffee Library" : "作品庫"}
          </h1>
        </div>

        <a
          href={`/${locale}/cart/`}
          class="inline-flex items-center gap-2 border border-border/20 px-4 py-2 text-xs tracking-[0.12em] uppercase text-text transition duration-150 ease-editorial hover:border-border/40"
        >
          {locale === "en" ? "Cart" : "購物車"}
          <span class="text-muted">(<span data-cart-count>0</span>)</span>
          <span class="text-muted">· HK$<span data-cart-subtotal>0</span></span>
        </a>
      </div>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-14 md:gap-16">
        {coffees.map(coffee => <CoffeeCard coffee={coffee} locale={locale} />)}
      </div>
    </Container>
  </Section>

  <Footer />
  <WeChatDrawer />

  <script>
    import {
      bindCartAddButtons,
      bindCartCountBadges,
      getCartSubtotal,
      readCart,
    } from "@/scripts/cart";

    const renderSubtotal = () => {
      const subtotal = getCartSubtotal(readCart());
      document.querySelectorAll<HTMLElement>("[data-cart-subtotal]").forEach(node => {
        node.textContent = String(subtotal);
      });
    };

    bindCartAddButtons();
    bindCartCountBadges();
    renderSubtotal();
    window.addEventListener("amz-cart:changed", renderSubtotal);
  </script>
</Layout>
