---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Container from "@/components/layout/Container.astro";
import Section from "@/components/layout/Section.astro";
import CoffeeCard from "@/components/coffee/CoffeeCard.astro";
import WeChatDrawer from "@/components/wechat/WeChatDrawer.astro";
import { isLocale, type Locale } from "@/data/locales";
import { getAllCoffees } from "@/utils/getCoffees";

export const prerender = false;

const localeParam = Astro.params.locale;
if (!isLocale(localeParam)) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const locale: Locale = localeParam;
const path = Astro.url.pathname;
const coffees = await getAllCoffees();

type FilterTag = {
  key: string;
  label: string;
};

type CoffeeCardModel = {
  coffee: (typeof coffees)[number];
  search: string;
  tags: FilterTag[];
};

const normalizeTagKey = (value: string) =>
  value
    .toLowerCase()
    .trim()
    .replace(/[·•/]+/g, " ")
    .replace(/\s+/g, "-")
    .replace(/[^a-z0-9-\u4e00-\u9fff]/g, "")
    .replace(/-{2,}/g, "-")
    .replace(/^-+|-+$/g, "");

const getCountryTag = (origin: string) =>
  origin
    .split(/[·•]/g)
    .map(part => part.trim())
    .find(Boolean) ?? origin.trim();

const coffeeCards: CoffeeCardModel[] = coffees.map(coffee => {
  const title = coffee.data.title[locale];
  const origin = coffee.data.origin[locale];
  const process = coffee.data.process[locale];

  const tags: FilterTag[] = [];
  for (const label of [process, getCountryTag(origin)]) {
    const normalizedLabel = label.trim();
    const key = normalizeTagKey(normalizedLabel);
    if (!normalizedLabel || !key || tags.some(tag => tag.key === key)) {
      continue;
    }
    tags.push({ key, label: normalizedLabel });
  }

  const search = [
    title,
    origin,
    process,
    coffee.data.notes[locale],
    coffee.data.story[locale],
    ...coffee.data.tasting[locale],
  ]
    .join(" ")
    .toLowerCase();

  return {
    coffee,
    search,
    tags,
  };
});

const filterTagMap = new Map<string, string>();
for (const card of coffeeCards) {
  for (const tag of card.tags) {
    if (!filterTagMap.has(tag.key)) {
      filterTagMap.set(tag.key, tag.label);
    }
  }
}

const filterTags: FilterTag[] = Array.from(filterTagMap.entries()).map(
  ([key, label]) => ({
    key,
    label,
  })
);

const title = locale === "en" ? "Coffee" : "Coffee";
const description =
  locale === "en"
    ? "Current AMZ Sensory releases with tasting notes."
    : "AMZ Sensory 當前作品與風味資訊。";
---

<Layout
  locale={locale}
  title={`AMZ Sensory | ${title}`}
  description={description}
>
  <Header locale={locale} path={path} />

  <Section>
    <Container>
      <div class="flex flex-wrap items-end justify-between gap-5">
        <div>
          <p class="text-xs tracking-[0.18em] text-muted uppercase">
            Current Releases
          </p>
          <h1 class="mt-3 font-serif text-4xl tracking-[-0.02em]">
            {locale === "en" ? "Coffee Library" : "作品庫"}
          </h1>
        </div>
      </div>

      <div class="mt-10 grid gap-10 md:grid-cols-[170px_1fr] md:gap-12">
        <aside class="self-start md:sticky md:top-[124px]">
          <p class="text-[10px] tracking-[0.14em] text-muted/75 uppercase">
            {locale === "en" ? "Tags" : "標籤"}
          </p>
          <div class="mt-4 grid gap-3" data-coffee-tag-list>
            <button
              type="button"
              class="w-fit bg-transparent px-0 py-0 text-left text-[15px] text-muted transition duration-150 ease-editorial hover:text-text data-[active=true]:text-text data-[active=true]:underline data-[active=true]:underline-offset-4"
              data-coffee-tag="all"
              data-active="true"
            >
              {locale === "en" ? "All" : "全部"}
            </button>
            {filterTags.map(tag => (
              <button
                type="button"
                class="w-fit bg-transparent px-0 py-0 text-left text-[15px] text-muted transition duration-150 ease-editorial hover:text-text data-[active=true]:text-text data-[active=true]:underline data-[active=true]:underline-offset-4"
                data-coffee-tag={tag.key}
                data-active="false"
              >
                {tag.label}
              </button>
            ))}
          </div>
        </aside>

        <div>
          <p class="text-[11px] text-muted/70" data-coffee-result-count></p>

          <div class="mt-6 grid grid-cols-1 gap-14 md:grid-cols-2 md:gap-16" data-coffee-grid>
            {coffeeCards.map(card => (
              <div
                data-coffee-item
                data-search={card.search}
                data-tags={card.tags.map(tag => tag.key).join(",")}
              >
                <CoffeeCard coffee={card.coffee} locale={locale} />
              </div>
            ))}
          </div>

          <p class="mt-8 hidden text-sm text-muted" data-coffee-empty>
            {locale === "en"
              ? "No matching coffees. Try another keyword or tag."
              : "找不到符合條件的作品，請更換關鍵字或標籤。"}
          </p>
        </div>
      </div>
    </Container>
  </Section>

  <Footer />
  <WeChatDrawer />

  <script>
    import { bindCartAddButtons, bindCartCountBadges } from "@/scripts/cart";

    type CoffeeListWindow = Window & {
      __amzCoffeeListBound?: boolean;
      __amzCoffeeListCleanup?: () => void;
    };

    const setupCoffeeList = (): boolean => {
      const searchInputs = Array.from(
        document.querySelectorAll<HTMLInputElement>("[data-global-coffee-search]")
      );
      const tagList = document.querySelector<HTMLElement>(
        "[data-coffee-tag-list]"
      );
      const resultNode = document.querySelector<HTMLElement>(
        "[data-coffee-result-count]"
      );
      const emptyNode =
        document.querySelector<HTMLElement>("[data-coffee-empty]");
      const items = Array.from(
        document.querySelectorAll<HTMLElement>("[data-coffee-item]")
      );

      bindCartAddButtons();
      bindCartCountBadges();

      if (!tagList || !resultNode || !emptyNode) {
        return false;
      }

      const win = window as CoffeeListWindow;
      win.__amzCoffeeListCleanup?.();

      let activeTag = "all";
      const tagButtons = Array.from(
        tagList.querySelectorAll<HTMLButtonElement>("[data-coffee-tag]")
      );

      const isEnglish = document.documentElement.lang
        .toLowerCase()
        .startsWith("en");

      const renderResultCount = (count: number) => {
        if (isEnglish) {
          resultNode.textContent = `${count} result${count === 1 ? "" : "s"}`;
          return;
        }
        resultNode.textContent = `${count} 項作品`;
      };

      const applyFilters = () => {
        const keyword = (searchInputs[0]?.value ?? "").trim().toLowerCase();
        let visible = 0;

        for (const item of items) {
          const searchText = (item.dataset.search ?? "").toLowerCase();
          const tags = (item.dataset.tags ?? "")
            .split(",")
            .map(tag => tag.trim())
            .filter(Boolean);

          const matchesSearch = keyword.length < 1 || searchText.includes(keyword);
          const matchesTag = activeTag === "all" || tags.includes(activeTag);
          const show = matchesSearch && matchesTag;

          item.classList.toggle("hidden", !show);
          visible += show ? 1 : 0;
        }

        renderResultCount(visible);
        emptyNode.classList.toggle("hidden", visible > 0);
      };

      const syncActiveTag = () => {
        for (const button of tagButtons) {
          const tag = button.dataset.coffeeTag ?? "all";
          button.dataset.active = tag === activeTag ? "true" : "false";
        }
      };

      const handleSearch = () => {
        applyFilters();
      };

      const handleSearchInput = (event: Event) => {
        const input = event.currentTarget as HTMLInputElement;
        const value = input.value;
        searchInputs.forEach(node => {
          if (node !== input) {
            node.value = value;
          }
        });
        handleSearch();
      };

      const handleTagClick = (event: Event) => {
        const target = event.target as HTMLElement | null;
        const button = target?.closest<HTMLButtonElement>("[data-coffee-tag]");
        if (!button) return;
        activeTag = button.dataset.coffeeTag ?? "all";
        syncActiveTag();
        applyFilters();
      };

      const searchFromUrl = new URL(window.location.href).searchParams.get("q");
      const initialSearch =
        searchFromUrl?.trim() ??
        searchInputs.find(node => node.value.trim().length > 0)?.value ??
        "";
      searchInputs.forEach(node => {
        node.value = initialSearch;
        node.addEventListener("input", handleSearchInput);
      });
      tagList.addEventListener("click", handleTagClick);

      syncActiveTag();
      applyFilters();

      win.__amzCoffeeListCleanup = () => {
        searchInputs.forEach(node => {
          node.removeEventListener("input", handleSearchInput);
        });
        tagList.removeEventListener("click", handleTagClick);
      };

      return true;
    };

    const runCoffeeListInit = () => {
      if (setupCoffeeList()) return;
      window.requestAnimationFrame(() => {
        setupCoffeeList();
      });
    };

    const win = window as CoffeeListWindow;
    if (!win.__amzCoffeeListBound) {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", runCoffeeListInit, {
          once: true,
        });
      } else {
        runCoffeeListInit();
      }
      document.addEventListener("astro:page-load", runCoffeeListInit);
      win.__amzCoffeeListBound = true;
    } else {
      runCoffeeListInit();
    }
  </script>
</Layout>
