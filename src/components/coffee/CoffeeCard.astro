---
import Aspect from "@/components/ui/Aspect.astro";
import type { Locale } from "@/data/locales";
import type { CoffeeEntry } from "@/utils/getCoffees";

type Props = {
  coffee: CoffeeEntry;
  locale: Locale;
};

const { coffee, locale } = Astro.props as Props;

const href = `/${locale}/coffee/${coffee.data.slug}/`;
const title = coffee.data.title[locale];
const tasting = coffee.data.tasting[locale].slice(0, 3).join(" · ");
const price = `HK$${coffee.data.priceHkd} / 100g`;
---

<article class="group grid gap-4">
  <a href={href} class="block">
    <Aspect class="rounded-[var(--radius)] border border-border/15 bg-surface p-4 md:p-5">
      <div class="h-full w-full rounded-[calc(var(--radius)-4px)] border border-border/10 bg-white/35 p-3">
        <img
          src={coffee.data.cover}
          alt={title}
          class="h-full w-full object-contain transition duration-300 ease-editorial group-hover:scale-[1.02]"
          loading="lazy"
        />
      </div>
    </Aspect>
  </a>

  <div>
    <a href={href} class="block">
      <h3 class="font-serif text-xl tracking-[-0.01em]">{title}</h3>
      <p class="mt-1 text-xs tracking-[0.12em] text-muted uppercase">
        {price}
      </p>
      <p class="mt-3 text-sm text-text/85">{tasting}</p>
    </a>

    <div class="mt-4 flex items-center gap-4 text-xs">
      <button
        type="button"
        class="border border-border/20 px-3 py-1.5 text-text transition duration-150 ease-editorial hover:border-border/40"
        data-cart-add
        data-stable-key={coffee.data.stable_key}
        data-slug={coffee.data.slug}
        data-title={title}
        data-price={coffee.data.priceHkd}
        data-cover={coffee.data.cover}
        data-added-label={locale === "en" ? "Added" : "已加入"}
      >
        {locale === "en" ? "Add to Cart" : "加入購物車"}
      </button>
      <a href={href} class="text-muted hover:text-text hover:underline underline-offset-4">
        {locale === "en" ? "View" : "檢視"}
      </a>
    </div>
  </div>
</article>
