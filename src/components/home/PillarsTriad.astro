---
import Container from "../layout/Container.astro";
import Section from "../layout/Section.astro";
import Divider from "../layout/Divider.astro";

const { locale } = Astro.props;

const pillars =
  locale === "en"
    ? [
        { title: "Structure", body: "Acidity isn't sharp; florals don't float away. Structure keeps flavor standing." },
        { title: "Light", body: "Ultra light is not thin—it keeps brightness for aromatics." },
        { title: "Clean", body: "A clean finish is the baseline for every adjustment." },
      ]
    : [
        { title: "Structure", body: "酸不是尖，花不是飄。結構讓風味站得住。" },
        { title: "Light", body: "極淺不是薄，是把亮度留給香氣。" },
        { title: "Clean", body: "尾韻乾淨，是我們對每一次調整的底線。" },
      ];
---
<Section tone="tight">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12">
      {pillars.map((pillar, i) => (
        <div class="group">
          <p class="text-xs tracking-[0.18em] uppercase text-muted">{String(i + 1).padStart(2, "0")}</p>
          <h3 class="mt-3 font-serif text-xl tracking-[-0.01em]">{pillar.title}</h3>
          <Divider class="my-5" />
          <p class="text-sm text-text/90">{pillar.body}</p>
        </div>
      ))}
    </div>
  </Container>
</Section>
