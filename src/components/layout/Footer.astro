---
import Container from "./Container.astro";

const locale = Astro.url.pathname.startsWith("/en/") ? "en" : "zh-hant";
const isEn = locale === "en";
const infoLinks = [
  {
    href: `/${locale}/contact/`,
    label: isEn ? "Contact Us" : "聯絡我們",
  },
  {
    href: `/${locale}/faq/`,
    label: "FAQ",
  },
  {
    href: `/${locale}/shipping/`,
    label: isEn ? "Shipping" : "配送資訊",
  },
  {
    href: `/${locale}/terms/`,
    label: isEn ? "Terms & Privacy" : "條款與隱私",
  },
  {
    href: `/${locale}/privacy/`,
    label: isEn ? "Privacy Policy" : "隱私政策",
  },
];
---
<footer class="border-t border-border/10 bg-surface" data-locale={locale}>
  <Container class="py-12 text-xs text-muted">
    <div class="grid gap-10 md:grid-cols-3 md:gap-12">
      <div class="grid gap-4">
        <p class="font-serif text-2xl tracking-[-0.01em] text-text">
          {isEn ? "Key information" : "重要資訊"}
        </p>
        <div class="grid gap-3 text-sm">
          {infoLinks.map(link => (
            <a
              href={link.href}
              class="hover:text-text transition duration-150 ease-editorial"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <div class="grid gap-4">
        <p class="font-serif text-2xl tracking-[-0.01em] text-text">Newsletter</p>
        <p class="max-w-prose text-sm text-muted">
          {isEn
            ? "Get updates about new coffee releases and seasonal notes."
            : "接收新品發佈與風味更新通知。"}
        </p>
        <form class="flex items-stretch border border-border/20" data-newsletter-form>
          <input
            type="email"
            required
            placeholder={isEn ? "Email" : "電子信箱"}
            class="w-full bg-transparent px-4 py-3 text-sm text-text placeholder:text-muted"
            data-newsletter-email
          />
          <button
            type="submit"
            class="border-l border-border/20 px-4 text-sm text-text transition duration-150 ease-editorial hover:bg-text/5"
          >
            →
          </button>
        </form>
        <p class="text-xs text-muted hidden" data-newsletter-feedback></p>
      </div>

      <div class="grid gap-4">
        <p class="font-serif text-2xl tracking-[-0.01em] text-text">
          {isEn ? "Follow us" : "追蹤我們"}
        </p>
        <div class="flex items-center gap-4 text-sm">
          <a class="hover:text-text transition duration-150 ease-editorial" href="#" aria-label="Instagram">Instagram</a>
          <a class="hover:text-text transition duration-150 ease-editorial" href="#" aria-label="Facebook">Facebook</a>
          <a class="hover:text-text transition duration-150 ease-editorial" href="#" aria-label="YouTube">YouTube</a>
        </div>
        <div class="flex items-center gap-4 pt-2">
          <a
            class="hover:text-text transition duration-150 ease-editorial"
            href="mailto:hello@amzsensory.com"
          >
            hello@amzsensory.com
          </a>
          <button
            class="text-muted hover:text-text transition duration-150 ease-editorial"
            data-wechat-open
          >
            WeChat / QR
          </button>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-wrap items-center justify-between gap-4 border-t border-border/10 pt-5">
      <div class="flex items-center gap-3">
        <img src="/brand/logo.svg" alt="AMZ Sensory" class="h-5 w-auto opacity-80" />
        <span>© {new Date().getFullYear()} AMZ Sensory</span>
      </div>
      <p class="text-xs text-muted">
        {isEn ? "Demo subscription flow. No backend connected." : "訂閱流程僅示範，尚未接入後端。"}
      </p>
    </div>
  </Container>

  <script>
    const locale = document
      .querySelector<HTMLElement>("footer[data-locale]")
      ?.dataset.locale;
    const isEn = locale === "en";
    const form = document.querySelector<HTMLFormElement>("[data-newsletter-form]");
    const input = document.querySelector<HTMLInputElement>("[data-newsletter-email]");
    const feedback = document.querySelector<HTMLElement>("[data-newsletter-feedback]");

    form?.addEventListener("submit", event => {
      event.preventDefault();
      if (!input || !feedback) return;
      const email = input.value.trim();
      const isValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
      feedback.classList.remove("hidden");

      if (!isValid) {
        feedback.textContent = isEn ? "Please enter a valid email." : "請輸入有效的電子信箱。";
        return;
      }

      feedback.textContent = isEn
        ? "Thanks. Subscription demo received."
        : "已收到訂閱示範提交。";
      input.value = "";
    });
  </script>
</footer>
