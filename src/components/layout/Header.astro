---
import LangSwitch from "./LangSwitch.astro";
import type { Locale } from "@/data/locales";
import { NAV_ITEMS } from "@/data/sitePages";

const { locale, path } = Astro.props as { locale: Locale; path: string };

const nav = NAV_ITEMS[locale];
const methodIndex =
  locale === "en"
    ? [
        { label: "Temperature Bands", href: "/en/method/temperature-bands/" },
        { label: "Development Control", href: "/en/method/development-control/" },
        { label: "Extraction Readiness", href: "/en/method/extraction-readiness/" },
      ]
    : [
        {
          label: "溫區分層",
          href: "/zh-hant/method/temperature-bands/",
        },
        {
          label: "發展控制",
          href: "/zh-hant/method/development-control/",
        },
        {
          label: "萃取準備度",
          href: "/zh-hant/method/extraction-readiness/",
        },
      ];
const originsIndex =
  locale === "en"
    ? [
        { label: "Traceability", href: "/en/origins/traceability/" },
        {
          label: "Long-Term Relationships",
          href: "/en/origins/long-term-relationships/",
        },
        { label: "Verifiable Language", href: "/en/origins/verifiable-language/" },
      ]
    : [
        { label: "可追溯性", href: "/zh-hant/origins/traceability/" },
        {
          label: "長期合作關係",
          href: "/zh-hant/origins/long-term-relationships/",
        },
        { label: "可驗證語言", href: "/zh-hant/origins/verifiable-language/" },
      ];
const responsibilityIndex =
  locale === "en"
    ? [
        { label: "Packaging", href: "/en/responsibility/packaging-discipline/" },
        { label: "Buying", href: "/en/responsibility/buying-discipline/" },
        { label: "Waste", href: "/en/responsibility/waste-control/" },
      ]
    : [
        { label: "包裝策略", href: "/zh-hant/responsibility/packaging-discipline/" },
        { label: "採購紀律", href: "/zh-hant/responsibility/buying-discipline/" },
        { label: "減廢節奏", href: "/zh-hant/responsibility/waste-control/" },
      ];
const philosophyIndex =
  locale === "en"
    ? [
        { label: "Aesthetic First", href: "/en/philosophy/aesthetic-first/" },
        { label: "Proof Over Claims", href: "/en/philosophy/proof-over-claims/" },
        { label: "Restraint", href: "/en/philosophy/restraint/" },
      ]
    : [
        { label: "審美先行", href: "/zh-hant/philosophy/aesthetic-first/" },
        { label: "證據優先", href: "/zh-hant/philosophy/proof-over-claims/" },
        { label: "節制", href: "/zh-hant/philosophy/restraint/" },
      ];

const sectionIndexes: Record<string, { label: string; href: string }[]> = {
  [locale === "en" ? "/en/method/" : "/zh-hant/method/"]: methodIndex,
  [locale === "en" ? "/en/origins/" : "/zh-hant/origins/"]: originsIndex,
  [locale === "en" ? "/en/responsibility/" : "/zh-hant/responsibility/"]:
    responsibilityIndex,
  [locale === "en" ? "/en/philosophy/" : "/zh-hant/philosophy/"]: philosophyIndex,
};
const coffeeSearchPlaceholder =
  locale === "en" ? "Search coffee" : "搜尋作品";
const coffeeSearchLabel = locale === "en" ? "Search coffee" : "搜尋作品";
---
<header class="sticky top-0 z-50 w-full border-b border-border/10 bg-surface/90 backdrop-blur">
  <div class="border-b border-border/10 bg-surface/95">
    <div class="mx-auto flex h-8 w-full max-w-[1280px] items-center justify-center px-3 sm:px-6 lg:px-8">
      <p class="w-full truncate text-center text-[10px] leading-none tracking-[0.14em] text-muted uppercase sm:text-[12px] sm:tracking-[0.16em]">
        Floral First · Ultra Light · Structure / Light / Clean
      </p>
    </div>
  </div>

  <div class="mx-auto flex h-[64px] w-full max-w-[1280px] items-center justify-between px-4 sm:px-6 md:hidden">
    <button
      type="button"
      class="inline-flex h-9 w-9 items-center justify-center border border-border/20 text-text"
      aria-label={locale === "en" ? "Open menu" : "開啟選單"}
      data-mobile-nav-open
    >
      <span class="text-lg leading-none">≡</span>
    </button>

    <a href={locale === "en" ? "/en/" : "/zh-hant/"} class="flex items-center justify-center">
      <img src="/brand/logo.svg" alt="AMZ Sensory" class="h-7 w-auto" />
    </a>

    <button
      type="button"
      class="inline-flex h-9 w-9 items-center justify-center rounded-[calc(var(--radius)*0.95)] border border-border/20 text-text"
      aria-label={locale === "en" ? "Open cart" : "開啟購物車"}
      data-cart-drawer-open
    >
      <svg
        viewBox="0 0 24 24"
        aria-hidden="true"
        class="h-[18px] w-[18px]"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
      >
        <circle cx="9" cy="20" r="1.1"></circle>
        <circle cx="18" cy="20" r="1.1"></circle>
        <path d="M3 4h2.2l2.1 10.2h10.6l2.2-7.2H6.4"></path>
      </svg>
    </button>
  </div>

  <div class="mx-auto hidden h-[72px] w-full max-w-[1280px] grid-cols-[1fr_auto_1fr] items-center px-4 sm:px-6 md:grid lg:px-8">
    <nav class="hidden w-full items-center justify-start gap-5 justify-self-start text-sm text-text/90 md:flex">
      {nav.map(item => {
        const isActive = path.startsWith(item.href);
        const isMethodRoot = item.href.endsWith("/method/");
        const isOriginsRoot = item.href.endsWith("/origins/");
        const isResponsibilityRoot = item.href.endsWith("/responsibility/");
        const isPhilosophyRoot = item.href.endsWith("/philosophy/");

        if (isMethodRoot) {
          return (
            <div class="group/method relative">
              <a
                class:list={[
                  "inline-flex items-center gap-1 transition duration-150 ease-editorial hover:underline underline-offset-6",
                  isActive && "active-nav",
                ]}
                href={item.href}
              >
                {item.label}
                <svg
                  viewBox="0 0 10 6"
                  aria-hidden="true"
                  class="h-[10px] w-[10px] text-muted transition duration-150 group-hover/method:text-text"
                >
                  <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z"
                    fill="currentColor"
                  ></path>
                </svg>
              </a>

              <div class="pointer-events-none invisible absolute left-0 top-full z-40 pt-4 opacity-0 transition duration-150 ease-editorial group-hover/method:pointer-events-auto group-hover/method:visible group-hover/method:opacity-100 group-focus-within/method:pointer-events-auto group-focus-within/method:visible group-focus-within/method:opacity-100">
                <div class="min-w-[360px] border border-border/15 bg-white p-6">
                  <div class="grid gap-4">
                    {methodIndex.map(link => (
                      <a
                        href={link.href}
                        class="text-[15px] text-text/90 transition duration-150 ease-editorial hover:text-text"
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          );
        }

        if (isOriginsRoot) {
          return (
            <div class="group/origins relative">
              <a
                class:list={[
                  "inline-flex items-center gap-1 transition duration-150 ease-editorial hover:underline underline-offset-6",
                  isActive && "active-nav",
                ]}
                href={item.href}
              >
                {item.label}
                <svg
                  viewBox="0 0 10 6"
                  aria-hidden="true"
                  class="h-[10px] w-[10px] text-muted transition duration-150 group-hover/origins:text-text"
                >
                  <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z"
                    fill="currentColor"
                  ></path>
                </svg>
              </a>

              <div class="pointer-events-none invisible absolute left-0 top-full z-40 pt-4 opacity-0 transition duration-150 ease-editorial group-hover/origins:pointer-events-auto group-hover/origins:visible group-hover/origins:opacity-100 group-focus-within/origins:pointer-events-auto group-focus-within/origins:visible group-focus-within/origins:opacity-100">
                <div class="min-w-[360px] border border-border/15 bg-white p-6">
                  <div class="grid gap-4">
                    {originsIndex.map(link => (
                      <a
                        href={link.href}
                        class="text-[15px] text-text/90 transition duration-150 ease-editorial hover:text-text"
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          );
        }

        if (isResponsibilityRoot) {
          return (
            <div class="group/responsibility relative">
              <a
                class:list={[
                  "inline-flex items-center gap-1 transition duration-150 ease-editorial hover:underline underline-offset-6",
                  isActive && "active-nav",
                ]}
                href={item.href}
              >
                {item.label}
                <svg
                  viewBox="0 0 10 6"
                  aria-hidden="true"
                  class="h-[10px] w-[10px] text-muted transition duration-150 group-hover/responsibility:text-text"
                >
                  <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z"
                    fill="currentColor"
                  ></path>
                </svg>
              </a>

              <div class="pointer-events-none invisible absolute left-0 top-full z-40 pt-4 opacity-0 transition duration-150 ease-editorial group-hover/responsibility:pointer-events-auto group-hover/responsibility:visible group-hover/responsibility:opacity-100 group-focus-within/responsibility:pointer-events-auto group-focus-within/responsibility:visible group-focus-within/responsibility:opacity-100">
                <div class="min-w-[360px] border border-border/15 bg-white p-6">
                  <div class="grid gap-4">
                    {responsibilityIndex.map(link => (
                      <a
                        href={link.href}
                        class="text-[15px] text-text/90 transition duration-150 ease-editorial hover:text-text"
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          );
        }

        if (isPhilosophyRoot) {
          return (
            <div class="group/philosophy relative">
              <a
                class:list={[
                  "inline-flex items-center gap-1 transition duration-150 ease-editorial hover:underline underline-offset-6",
                  isActive && "active-nav",
                ]}
                href={item.href}
              >
                {item.label}
                <svg
                  viewBox="0 0 10 6"
                  aria-hidden="true"
                  class="h-[10px] w-[10px] text-muted transition duration-150 group-hover/philosophy:text-text"
                >
                  <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z"
                    fill="currentColor"
                  ></path>
                </svg>
              </a>

              <div class="pointer-events-none invisible absolute left-0 top-full z-40 pt-4 opacity-0 transition duration-150 ease-editorial group-hover/philosophy:pointer-events-auto group-hover/philosophy:visible group-hover/philosophy:opacity-100 group-focus-within/philosophy:pointer-events-auto group-focus-within/philosophy:visible group-focus-within/philosophy:opacity-100">
                <div class="min-w-[360px] border border-border/15 bg-white p-6">
                  <div class="grid gap-4">
                    {philosophyIndex.map(link => (
                      <a
                        href={link.href}
                        class="text-[15px] text-text/90 transition duration-150 ease-editorial hover:text-text"
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          );
        }

        return (
          <a
            class:list={[
              "transition duration-150 ease-editorial hover:underline underline-offset-6",
              isActive && "active-nav",
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <a href={locale === "en" ? "/en/" : "/zh-hant/"} class="flex items-center justify-center">
      <img src="/brand/logo.svg" alt="AMZ Sensory" class="h-8 w-auto" />
    </a>

    <div class="flex w-full items-center justify-end justify-self-end gap-4">
      <label class="relative hidden items-center md:flex">
        <svg
          viewBox="0 0 24 24"
          aria-hidden="true"
          class="pointer-events-none absolute left-2.5 h-[14px] w-[14px] text-muted"
          fill="none"
          stroke="currentColor"
          stroke-width="1.7"
        >
          <circle cx="11" cy="11" r="6"></circle>
          <path d="M20 20l-3.6-3.6"></path>
        </svg>
        <input
          type="search"
          class="w-[184px] rounded-[calc(var(--radius)*0.95)] border border-border/15 bg-surface/65 py-1.5 pl-8 pr-3 text-xs text-text transition duration-150 ease-editorial placeholder:text-muted/70 focus:border-text/30 focus:outline-none"
          placeholder={coffeeSearchPlaceholder}
          aria-label={coffeeSearchLabel}
          data-global-coffee-search
        />
      </label>
      <LangSwitch locale={locale} path={path} />
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-[calc(var(--radius)*0.95)] border border-border/20 text-text transition duration-150 ease-editorial hover:border-border/40"
        aria-label={locale === "en" ? "Open cart" : "開啟購物車"}
        data-cart-drawer-open
      >
        <svg
          viewBox="0 0 24 24"
          aria-hidden="true"
          class="h-[18px] w-[18px]"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
        >
          <circle cx="9" cy="20" r="1.1"></circle>
          <circle cx="18" cy="20" r="1.1"></circle>
          <path d="M3 4h2.2l2.1 10.2h10.6l2.2-7.2H6.4"></path>
        </svg>
      </button>
    </div>
  </div>

  <dialog
    id="mobile-nav-dialog"
    class="m-0 h-full w-full max-w-none border-0 bg-surface/95 p-0 text-text backdrop:bg-text/35 md:hidden"
  >
    <div class="mx-auto grid h-full w-full max-w-[1280px] grid-rows-[auto_1fr] px-4 sm:px-6">
      <div class="flex h-[64px] items-center justify-between border-b border-border/10">
        <a href={locale === "en" ? "/en/" : "/zh-hant/"} class="flex items-center justify-center">
          <img src="/brand/logo.svg" alt="AMZ Sensory" class="h-7 w-auto" />
        </a>
        <button
          type="button"
          class="inline-flex h-9 w-9 items-center justify-center border border-border/20 text-text"
          aria-label={locale === "en" ? "Close menu" : "關閉選單"}
          data-mobile-nav-close
        >
          <span class="text-lg leading-none">×</span>
        </button>
      </div>

      <div class="overflow-y-auto py-6">
        <div class="grid gap-6">
          {nav.map(item => {
            const isActive = path.startsWith(item.href);
            const children = sectionIndexes[item.href] ?? [];
            return (
              <div class="grid gap-3">
                <a
                  href={item.href}
                  class:list={[
                    "text-xl font-serif tracking-[-0.01em]",
                    isActive ? "underline underline-offset-8" : "hover:underline underline-offset-8",
                  ]}
                >
                  {item.label}
                </a>
                {children.length > 0 && (
                  <div class="ml-1 grid gap-2 border-l border-border/20 pl-4">
                    {children.map(link => (
                      <a
                        href={link.href}
                        class="text-sm text-muted transition duration-150 ease-editorial hover:text-text"
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            );
          })}
        </div>

        <div class="mt-8 grid gap-4 border-t border-border/10 pt-6 text-sm text-muted">
          <label class="relative mt-1 flex items-center">
            <svg
              viewBox="0 0 24 24"
              aria-hidden="true"
              class="pointer-events-none absolute left-2.5 h-[14px] w-[14px] text-muted"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
            >
              <circle cx="11" cy="11" r="6"></circle>
              <path d="M20 20l-3.6-3.6"></path>
            </svg>
            <input
              type="search"
              class="w-full rounded-[calc(var(--radius)*0.95)] border border-border/15 bg-surface/65 py-2 pl-8 pr-3 text-sm text-text transition duration-150 ease-editorial placeholder:text-muted/70 focus:border-text/30 focus:outline-none"
              placeholder={coffeeSearchPlaceholder}
              aria-label={coffeeSearchLabel}
              data-global-coffee-search
            />
          </label>
          <LangSwitch locale={locale} path={path} />
        </div>
      </div>
    </div>
  </dialog>

  <script>
    import { bindCartCountBadges } from "@/scripts/cart";

    type HeaderWindow = Window & {
      __amzHeaderBound?: boolean;
      __amzHeaderCleanup?: () => void;
    };

    const setupHeader = (): boolean => {
      const mobileDialog =
        document.querySelector<HTMLDialogElement>("#mobile-nav-dialog");
      const openButton =
        document.querySelector<HTMLElement>("[data-mobile-nav-open]");
      const closeButton =
        mobileDialog?.querySelector<HTMLElement>("[data-mobile-nav-close]");

      if (!mobileDialog || !openButton || !closeButton) {
        bindCartCountBadges();
        return false;
      }

      const win = window as HeaderWindow;
      win.__amzHeaderCleanup?.();

      const closeDialog = () => {
        if (!mobileDialog.open) return;
        mobileDialog.close();
        document.body.style.overflow = "";
      };

      const handleOpen = () => {
        mobileDialog.showModal();
        document.body.style.overflow = "hidden";
      };

      const handleClose = () => {
        closeDialog();
      };

      const handleDialogClick = (event: MouseEvent) => {
        if (event.target === mobileDialog) closeDialog();
      };

      const handleDialogClosed = () => {
        document.body.style.overflow = "";
      };

      const navLinks = Array.from(mobileDialog.querySelectorAll("a"));
      const handleNavLinkClick = () => {
        closeDialog();
      };

      const searchInputs = Array.from(
        document.querySelectorAll<HTMLInputElement>("[data-global-coffee-search]")
      );
      const activeLocale = document.documentElement.lang
        .toLowerCase()
        .startsWith("en")
        ? "en"
        : "zh-hant";
      const searchBasePath = `/${activeLocale}/coffee/`;
      const queryFromUrl = new URL(window.location.href).searchParams.get("q") ?? "";
      if (queryFromUrl.length > 0) {
        searchInputs.forEach(input => {
          input.value = queryFromUrl;
        });
      }

      const handleSearchInput = (event: Event) => {
        const source = event.currentTarget as HTMLInputElement;
        const value = source.value;
        searchInputs.forEach(input => {
          if (input !== source) input.value = value;
        });
      };

      const handleSearchKeydown = (event: KeyboardEvent) => {
        if (event.key !== "Enter") return;
        event.preventDefault();

        const input = event.currentTarget as HTMLInputElement;
        const keyword = input.value.trim();
        const url = new URL(searchBasePath, window.location.origin);
        if (keyword.length > 0) {
          url.searchParams.set("q", keyword);
        }
        window.location.href = `${url.pathname}${url.search}`;
      };

      openButton.addEventListener("click", handleOpen);
      closeButton.addEventListener("click", handleClose);
      mobileDialog.addEventListener("click", handleDialogClick);
      mobileDialog.addEventListener("close", handleDialogClosed);
      navLinks.forEach(link => {
        link.addEventListener("click", handleNavLinkClick);
      });
      searchInputs.forEach(input => {
        input.addEventListener("input", handleSearchInput);
        input.addEventListener("keydown", handleSearchKeydown);
      });

      bindCartCountBadges();

      win.__amzHeaderCleanup = () => {
        openButton.removeEventListener("click", handleOpen);
        closeButton.removeEventListener("click", handleClose);
        mobileDialog.removeEventListener("click", handleDialogClick);
        mobileDialog.removeEventListener("close", handleDialogClosed);
        navLinks.forEach(link => {
          link.removeEventListener("click", handleNavLinkClick);
        });
        searchInputs.forEach(input => {
          input.removeEventListener("input", handleSearchInput);
          input.removeEventListener("keydown", handleSearchKeydown);
        });
      };

      return true;
    };

    const runHeaderInit = () => {
      if (setupHeader()) return;
      window.requestAnimationFrame(() => {
        setupHeader();
      });
    };

    const win = window as HeaderWindow;
    if (!win.__amzHeaderBound) {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", runHeaderInit, {
          once: true,
        });
      } else {
        runHeaderInit();
      }
      document.addEventListener("astro:page-load", runHeaderInit);
      win.__amzHeaderBound = true;
    } else {
      runHeaderInit();
    }
  </script>
</header>
